HOST=0.0.0.0
PORT=8787
PUBLIC_PROTOCOL=http
# PUBLIC_HOST 留空时会自动探测当前机器的局域网可访问地址
PUBLIC_HOST=
# 如果你有固定域名 / 反向代理地址，优先直接填 PUBLIC_BASE_URL
PUBLIC_BASE_URL=
# 可选：本地 bridge 的 tunnel 前转发地址，默认会按 PORT 推导为 http://127.0.0.1:<PORT>
TUNNEL_LOCAL_URL=
CONNECTOR_NAME="Clawboard Bridge"
NODE_ID=node-local-1
PLATFORM=linux
NETWORK_MODE=direct
PAIR_CODE=LX-472911
API_TOKEN=
STATE_FILE=
