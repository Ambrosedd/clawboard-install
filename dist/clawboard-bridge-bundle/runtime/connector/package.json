{
  "name": "clawboard-connector",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight local-first Connector skeleton for Clawboard",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "build:sample-state": "node tools/runtime-jsonl-to-state.js --input runtime-events.sample.jsonl --output sample-runtime-state.generated.json"
  },
  "engines": {
    "node": ">=20"
  }
}
